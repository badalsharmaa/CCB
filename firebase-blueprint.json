{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a user",
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "preparing", "ready", "completed", "cancelled"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["orderId", "userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "User orders"
    }
  }
}
